# Server
PORT=3000
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/streamit"

# Better Auth
# Use the backend origin here, not the frontend origin.
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Frontend
# Public user-facing frontend origin used for CORS and payment return URLs.
FRONTEND_URL="http://localhost:5173"

# Email delivery
# Used by Better Auth OTP / verification emails.
RESEND_API_KEY="re_replace_me"

# File storage (required at boot because the S3 client is initialized eagerly)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="replace-me"
AWS_SECRET_ACCESS_KEY="replace-me"
S3_BUCKET_NAME="streamit-files"

# LiveKit streaming
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="replace-me"
LIVEKIT_API_SECRET="replace-me"

# Dodo Payments
DODO_API_KEY="replace-me"
DODO_WEBHOOK_SECRET="replace-me"

# Admin exports
# Optional: falls back to BETTER_AUTH_SECRET when omitted.
ADMIN_EXPORT_SIGNING_SECRET="replace-with-a-separate-secret"
