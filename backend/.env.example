# ============================================
# SERVER CONFIGURATION
# ============================================

# Port for the backend server
PORT=3000

# Environment mode (development, production, test)
NODE_ENV="development"

# ============================================
# DATABASE
# ============================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Connection pooling parameters:
# - connection_limit: Maximum number of connections in the pool (default: 10)
# - pool_timeout: Maximum time (seconds) to wait for a connection (default: 10)
# - connect_timeout: Maximum time (seconds) to wait for initial connection (default: 5)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/streamit?connection_limit=10&pool_timeout=20&connect_timeout=5"

# ============================================
# AUTHENTICATION (Better Auth)
# ============================================

# Secret key for JWT signing and encryption
# Generate a secure random string (min 32 characters)
# Example: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# Backend server URL (used for OAuth callbacks and session management)
# Use the backend origin here, not the frontend origin
BETTER_AUTH_URL="http://localhost:3000"

# ============================================
# FRONTEND URLS
# ============================================

# Public user-facing frontend URL
# Used for CORS, payment return URLs, and email links
FRONTEND_URL="http://localhost:5173"

# Admin dashboard URL
# Used for CORS, admin redirects, and notifications
# IMPORTANT: Must be set for admin dashboard to work properly
ADMIN_FRONTEND_URL="http://localhost:5174"

# ============================================
# EMAIL DELIVERY (Resend)
# ============================================

# Resend API key for sending transactional emails
# Used by Better Auth for OTP and verification emails
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_replace_me"

# ============================================
# FILE STORAGE (AWS S3)
# ============================================

# AWS region for S3 bucket
AWS_REGION="us-east-1"

# AWS credentials for S3 access
# Get from AWS IAM console
AWS_ACCESS_KEY_ID="replace-me"
AWS_SECRET_ACCESS_KEY="replace-me"

# S3 bucket name for file uploads
# Used for profile pictures, stream thumbnails, post media, etc.
S3_BUCKET_NAME="streamit-files"

# ============================================
# LIVE STREAMING (LiveKit)
# ============================================

# LiveKit server WebSocket URL
# Format: wss://your-project.livekit.cloud
LIVEKIT_URL="wss://your-project.livekit.cloud"

# LiveKit API credentials
# Get from LiveKit Cloud dashboard or self-hosted instance
LIVEKIT_API_KEY="replace-me"
LIVEKIT_API_SECRET="replace-me"

# ============================================
# PAYMENT GATEWAY (Dodo Payments)
# ============================================

# Dodo Payments API key
# Get from: https://dodopayments.com/dashboard
DODO_API_KEY="replace-me"

# Dodo webhook secret for verifying webhook signatures
# Get from Dodo Payments webhook settings
DODO_WEBHOOK_SECRET="replace-me"

# ============================================
# ADMIN & SECURITY
# ============================================

# Secret for signing admin data exports (CSV, JSON)
# Optional: falls back to BETTER_AUTH_SECRET if not provided
# Generate a separate secret for additional security
ADMIN_EXPORT_SIGNING_SECRET="replace-with-a-separate-secret"

# ============================================
# NOTES
# ============================================

# Development Setup:
# 1. Copy this file to .env
# 2. Replace all "replace-me" values with actual credentials
# 3. Run: bun install && bun run db:generate && bun run db:migrate
# 4. Seed data: bun run db:seed && bun run db:seed-discount
# 5. Promote admin: bun run admin:promote your@email.com
# 6. Start server: bun run dev

# Production Setup:
# - Set NODE_ENV="production"
# - Use strong secrets (min 32 characters)
# - Enable HTTPS for all URLs
# - Use production database with backups
# - Rotate secrets regularly
# - Enable AWS S3 bucket encryption
# - Configure proper CORS origins
