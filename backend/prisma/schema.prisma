  ADMIN
  SUPER_ADMIN
  MODERATOR
  FINANCE_ADMIN
  COMPLIANCE_OFFICER
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  NUDITY
  VIOLENCE
  COPYRIGHT
  MISINFORMATION
  SELF_HARM
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

// Stream report specific enums
enum StreamReportReason {
  INAPPROPRIATE_CONTENT
  HARASSMENT
  SPAM
  VIOLENCE
  COPYRIGHT
  OTHER
}

enum StreamReportStatus {
  PENDING
  REVIEWED
  RESOLVED
